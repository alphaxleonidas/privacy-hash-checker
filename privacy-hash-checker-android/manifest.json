{
  "manifest_version": 2,
  "name": "Privacy Hash Checker",
  "version": "4.0.1",
  "description": "Auto‑scan downloads by hash – opens VT page in new tab (Android).",
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "Privacy Hash Checker",
    "default_icon": "icon.svg"
  },
  "applications": {
    "gecko": {
      "id": "privacyhashchecker@android",
      "strict_min_version": "68.0"
    }
  }
}
